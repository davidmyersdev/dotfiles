#!/usr/bin/env bash

# Make sure the Caddy root cert is trusted by the system.
caddy trust

# Make sure the Caddy root cert is available to OpenSSL for Ruby.
ln -s $(brew --prefix)/var/lib/caddy/pki/authorities/local/root.crt $(brew --prefix)/etc/openssl@3/certs/caddy-root.pem
c_rehash $(brew --prefix)/etc/openssl@3/certs

# Make sure the service is running.
brew services restart caddy
