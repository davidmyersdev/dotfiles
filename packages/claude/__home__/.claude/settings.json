      "Bash(bat *)",
      "Bash(cat *)",
      "Bash(mv *)",
      "WebSearch"
    ],
    "deny": [
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(curl *)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(ssh *)",
      "Bash(sudo *)",
      "Bash(wget *)",
      "Read(.env)",
      "Read(.env.*.local)",
      "Read(.env.local)"
    ]
  }
}
