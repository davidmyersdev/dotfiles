{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "claude-api@anthropic-agent-skills": true,
    "dox-common@doximity-claude-code-tools": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "repo": "anthropics/skills",
        "source": "github"
      }
    },
    "doximity-claude-code-tools": {
      "source": {
        "source": "git",
        "url": "git@github.com:doximity/claude-code-tools.git"
      }
    }
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(bin/packwerk check *)",
      "Bash(bin/packwerk check)",
      "Bash(bin/packwerk validate *)",
      "Bash(bin/packwerk validate)",
      "Bash(bin/rails db:create)",
      "Bash(bin/rails db:migrate)",
      "Bash(bin/rails db:migrate:down *)",
      "Bash(bin/rails db:migrate:down)",
      "Bash(bin/rails db:migrate:status)",
      "Bash(bin/rails db:migrate:up *)",
      "Bash(bin/rails db:migrate:up)",
      "Bash(bin/rails db:schema:load)",
      "Bash(bin/rails generate *)",
      "Bash(bin/rspec *)",
      "Bash(bin/rubocop *)",
      "Bash(bin/rubocop)",
      "Bash(command -v *)",
      "Bash(echo $?)",
      "Bash(gh pr checks *)",
      "Bash(gh pr checks)",
      "Bash(gh pr list *)",
      "Bash(gh pr list)",
      "Bash(gh pr view *)",
      "Bash(gh pr view)",
      "Bash(gh repo view *)",
      "Bash(gh repo view)",
      "Bash(gh run list *)",
      "Bash(gh run list)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow list)",
      "Bash(gh workflow view *)",
      "Bash(git add *)",
      "Bash(git branch --list *)",
      "Bash(git branch --list)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git ls-files)",
      "Bash(git mv *)",
      "Bash(git show *)",
      "Bash(npm run build)",
      "Bash(npm run install)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(pnpm build)",
      "Bash(pnpm install)",
      "Bash(pnpm lint)",
      "Bash(pnpm test)",
      "Bash(test *)",
      "Bash(tldr *)",
      "Bash(which *)",
      "Bash(yarn build)",
      "Bash(yarn install)",
      "Bash(yarn lint *)",
      "Bash(yarn lint)",
      "Bash(yarn test *)",
      "Bash(yarn test)",
      "Bash(yarn vitest *)",
      "Edit(/**/*.js)",
      "Edit(/**/*.json)",
      "Edit(/**/*.md)",
      "Edit(/**/*.rb)",
      "Edit(/**/*.ts)",
      "Edit(/**/*.vue)",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:esbuild.github.io)",
      "WebFetch(domain:eslint.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:graphql-ruby.org)",
      "WebFetch(domain:graphql.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:openai.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:rollupjs.org)",
      "WebFetch(domain:rspec.info)",
      "WebFetch(domain:rubocop.org)",
      "WebFetch(domain:ruby-lang.org)",
      "WebFetch(domain:rubyonrails.org)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:viteplus.dev)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:voidzero.dev)",
      "WebFetch(domain:vuejs.org)"
