#!/usr/bin/env bash

# Ensure Homebrew itself is up to date.
brew update

# Re-generate the Homebrew init script in case it changed.
cat << EOF > ~/.zshrc.d/brew.zsh
#!/usr/bin/env zsh

# Note: This file is auto-generated by the \`bin/update\` script.
$(/opt/homebrew/bin/brew shellenv zsh)
EOF

# Re-generate the Worktrunk init script in case it changed.
cat << EOF > ~/.zshrc.d/worktrunk.zsh
#!/usr/bin/env zsh

# Note: This file is auto-generated by the \`bin/update\` script.
$(wt config shell init zsh)
EOF

# Ensure all dependencies are listed in the Brewfile.
brew bundle dump --describe --force

# Ensure all dependencies are up to date.
brew bundle upgrade

# Run cleanup tasks.
brew bundle cleanup --force
